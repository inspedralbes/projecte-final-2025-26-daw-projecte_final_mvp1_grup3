# ==========================================================
# Loopy - Variables d'Entorn Unificades (.env.example)
# ==========================================================

# --- APP CONFIG ---
APP_NAME=Loopy
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- DATABASE (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=loopy_db
DB_USERNAME=loopy
DB_PASSWORD=loopy_secret

# --- REDIS ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- SECRETS (JWT - compartit amb Laravel i Node) ---
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=4b2e95c71827e0f29601e4566112841c47b7fe53eab506fb3884be7e8735c623

# --- FRONTEND (Nuxt) ---
SOCKET_URL=http://localhost:3001
API_URL=http://localhost:8000

# --- EXTERNAL APIS ---
WGER_API_URL=https://wger.de/api/v2
WGER_API_TOKEN=your_wger_api_token

GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key
GOOGLE_BOOKS_API_KEY=your_google_books_api_key
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key

API_NINJAS_API_KEY=your_api_ninjas_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
